// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Teacher {
  id    String @id @default(cuid())
  name  String
  email String @unique

  quizzes Quiz[]
}

model Quiz {
  id        String  @id @default(cuid())
  title     String
  teacherId String
  teacher   Teacher @relation(fields: [teacherId], references: [id])
  timeLimit Int? // in minutes, null = no limit
  isOpen    Boolean @default(true)

  questions   Question[]
  submissions Submission[]

  createdAt DateTime @default(now())
}

model Question {
  id     String @id @default(cuid())
  quizId String
  quiz   Quiz   @relation(fields: [quizId], references: [id])

  question     String
  options      String[]
  correctIndex Int
}

model Submission {
  id        String @id @default(cuid())
  quizId    String
  student   String
  studentId String
  score     Int
  answers   Int[]

  quiz Quiz @relation(fields: [quizId], references: [id])

  createdAt DateTime @default(now())

  @@unique([quizId, studentId])
}

//for mock test

model BankQuestion {
  id           String   @id @default(cuid())
  sectionId    String
  section      Section  @relation(fields: [sectionId], references: [id])
  question     String
  options      String[]
  correctIndex Int
  explanation  String? // shown after submission
}



model Exam {
  id   String @id @default(cuid())
  name String @unique

  sections        Section[]
  mockTestResults MockTestResult[]
}

model Section {
  id        String @id @default(cuid())
  name      String
  examId    String
  exam      Exam   @relation(fields: [examId], references: [id])
  timeLimit Int

  questions BankQuestion[]

  @@unique([examId, name])
}

model MockTestResult {
  id          String   @id @default(cuid())
  examId      String
  exam        Exam     @relation(fields: [examId], references: [id])
  sectionId   String?
  studentName String
  studentId   String
  answers     Int[]
  score       Int
  totalQ      Int
  timeTaken   Int
  createdAt   DateTime @default(now())
}