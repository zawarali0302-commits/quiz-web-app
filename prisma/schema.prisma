generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma/client"
}
datasource db {
  provider = "postgresql"
}


model Teacher {
  id     String @id @default(cuid())
  name   String
  email  String @unique

  quizzes Quiz[]
}

model Quiz {
  id        String  @id @default(cuid())
  title     String
  teacherId String
  teacher   Teacher @relation(fields: [teacherId], references: [id])

  timeLimit Int? // minutes, null = unlimited
  isOpen    Boolean @default(true)

  questions   Question[]
  submissions Submission[]

  createdAt DateTime @default(now())

  @@index([teacherId])
}

model Question {
  id     String @id @default(cuid())
  quizId String
  quiz   Quiz   @relation(fields: [quizId], references: [id], onDelete: Cascade)

  question     String
  options      String[]
  correctIndex Int

  @@index([quizId])
}

model Submission {
  id        String @id @default(cuid())
  quizId    String
  studentId String
  student   String
  score     Int
  answers   Int[]

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([quizId, studentId])
  @@index([quizId])
}

/////////////////////////
// MOCK TEST SYSTEM
/////////////////////////

model Exam {
  id   String @id @default(cuid())
  name String @unique

  sections        Section[]
  mockTestResults MockTestResult[]
}

model Section {
  id        String @id @default(cuid())
  name      String
  examId    String
  exam      Exam   @relation(fields: [examId], references: [id], onDelete: Cascade)

  timeLimit Int

  questions       BankQuestion[]
  mockTestResults MockTestResult[]

  @@unique([examId, name])
  @@index([examId])
}

model BankQuestion {
  id           String  @id @default(cuid())
  sectionId    String
  section      Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  question     String
  options      String[]
  correctIndex Int
  explanation  String?

  @@index([sectionId])
}

model MockTestResult {
  id     String @id @default(cuid())

  examId String
  exam   Exam @relation(fields: [examId], references: [id], onDelete: Cascade)

  sectionId String
  section   Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  studentId   String
  studentName String

  answers   Int[]
  score     Int
  totalQ    Int
  timeTaken Int // seconds

  createdAt DateTime @default(now())

  @@index([examId])
  @@index([sectionId])
}